generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Utilisateur {
  id              Int        @id @default(autoincrement())
  email           String     @unique
  password        String
  nom             String
  prenom          String
  telephone       String?
  role            Role       @default(PARENT)
  estActif        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  eleve           Eleve?
  messagesRecus   Message[]  @relation("MessagesRecus")
  messagesEnvoyes Message[]  @relation("MessagesEnvoyes")
  parent          Parent?
  personnel       Personnel?
}

model Eleve {
  id              Int                @id @default(autoincrement())
  utilisateurId   Int                @unique
  matricule       String             @unique
  dateNaissance   DateTime
  classeId        Int?
  dateInscription DateTime           @default(now())
  estInscrit      Boolean            @default(true)
  classe          Classe?            @relation(fields: [classeId], references: [id])
  utilisateur     Utilisateur        @relation(fields: [utilisateurId], references: [id])
  parents         LienParentEleve[]
  notes           Note[]
  paiements       Paiement[]
  presences       Presence[]
  soumissions     SoumissionDevoir[]
}

model Classe {
  id              Int            @id @default(autoincrement())
  nom             String
  niveau          String
  salle           String?
  capaciteMax     Int            @default(30)
  titulaireId     Int?
  anneeScolaireId Int
  eleves          Eleve[]
  enseignements   Enseignement[]
  presences       Presence[]
}

model Enseignement {
  id              Int       @id @default(autoincrement())
  enseignantId    Int
  classeId        Int
  matiereId       Int
  heuresSemaine   Decimal?  @db.Decimal(5, 2)
  anneeScolaireId Int
  devoirs         Devoir[]
  classe          Classe    @relation(fields: [classeId], references: [id])
  enseignant      Personnel @relation(fields: [enseignantId], references: [id])
  matiere         Matiere   @relation(fields: [matiereId], references: [id])
  lecons          Lecon[]
  notes           Note[]
}

model Matiere {
  id            Int            @id @default(autoincrement())
  nom           String
  coefficient   Int            @default(1)
  enseignements Enseignement[]
}

model Lecon {
  id              Int          @id @default(autoincrement())
  enseignementId  Int
  titre           String
  contenu         String?
  fichierUrl      String?
  videoUrl        String?
  datePublication DateTime     @default(now())
  enseignement    Enseignement @relation(fields: [enseignementId], references: [id])
}

model Devoir {
  id              Int                @id @default(autoincrement())
  enseignementId  Int
  titre           String
  description     String?
  fichierUrl      String?
  dateLimite      DateTime
  datePublication DateTime           @default(now())
  enseignement    Enseignement       @relation(fields: [enseignementId], references: [id])
  soumissions     SoumissionDevoir[]
}

model SoumissionDevoir {
  id             Int      @id @default(autoincrement())
  devoirId       Int
  eleveId        Int
  fichierUrl     String
  dateSoumission DateTime @default(now())
  note           Decimal? @db.Decimal(5, 2)
  commentaire    String?
  isOffline      Boolean  @default(false)
  syncId         String?
  devoir         Devoir   @relation(fields: [devoirId], references: [id])
  eleve          Eleve    @relation(fields: [eleveId], references: [id])
}

model Presence {
  id           Int       @id @default(autoincrement())
  eleveId      Int
  classeId     Int
  date         DateTime
  statut       String
  heureArrivee DateTime?
  enseignantId Int?
  isOffline    Boolean   @default(false)
  syncId       String?
  classe       Classe    @relation(fields: [classeId], references: [id])
  eleve        Eleve     @relation(fields: [eleveId], references: [id])
}

model Paiement {
  id                   Int      @id @default(autoincrement())
  eleveId              Int
  montant              Int
  typeFrais            String
  modePaiement         String
  referenceTransaction String?
  statut               String   @default("valide")
  datePaiement         DateTime @default(now())
  recuUrl              String?
  saisiePar            Int?
  eleve                Eleve    @relation(fields: [eleveId], references: [id])
}

model Note {
  id             Int          @id @default(autoincrement())
  eleveId        Int
  enseignementId Int
  valeur         Decimal      @db.Decimal(5, 2)
  coefficient    Int          @default(1)
  dateSaisie     DateTime     @default(now())
  commentaire    String?
  enseignantId   Int?
  isOffline      Boolean      @default(false)
  syncId         String?
  eleve          Eleve        @relation(fields: [eleveId], references: [id])
  enseignement   Enseignement @relation(fields: [enseignementId], references: [id])
}

model Message {
  id             Int         @id @default(autoincrement())
  expediteurId   Int
  destinataireId Int
  sujet          String?
  contenu        String
  estLu          Boolean     @default(false)
  dateEnvoi      DateTime    @default(now())
  isOffline      Boolean     @default(false)
  syncId         String?
  destinataire   Utilisateur @relation("MessagesRecus", fields: [destinataireId], references: [id])
  expediteur     Utilisateur @relation("MessagesEnvoyes", fields: [expediteurId], references: [id])
}

model Parent {
  id            Int               @id @default(autoincrement())
  utilisateurId Int               @unique
  profession    String?
  eleves        LienParentEleve[]
  utilisateur   Utilisateur       @relation(fields: [utilisateurId], references: [id])
}

model LienParentEleve {
  parentId Int
  eleveId  Int
  lien     String @default("parent")
  eleve    Eleve  @relation(fields: [eleveId], references: [id])
  parent   Parent @relation(fields: [parentId], references: [id])

  @@id([parentId, eleveId])
}

model Personnel {
  id                 Int               @id @default(autoincrement())
  utilisateurId      Int               @unique
  matriculePersonnel String            @unique
  type               String
  dateEmbauche       DateTime          @default(now())
  salaireBase        Int?
  enseignements      Enseignement[]
  paiementsSalaires  PaiementSalaire[]
  utilisateur        Utilisateur       @relation(fields: [utilisateurId], references: [id])
}

model PaiementSalaire {
  id                   Int       @id @default(autoincrement())
  personnelId          Int
  mois                 Int
  annee                Int
  montant              Int
  statut               String    @default("paye")
  datePaiement         DateTime  @default(now())
  modePaiement         String
  referenceTransaction String?
  saisiePar            Int?
  personnel            Personnel @relation(fields: [personnelId], references: [id])
}

model Depense {
  id          Int      @id @default(autoincrement())
  categorie   String
  montant     Int
  dateDepense DateTime @default(now())
  description String?
  recuUrl     String?
  saisiePar   Int?
}

enum Role {
  SUPER_ADMIN
  DIRECTEUR_GENERAL
  DIRECTEUR_ETUDES
  COMPTABLE
  SECRETARIAT
  SURVEILLANT
  ENSEIGNANT
  PARENT
  ELEVE
}
